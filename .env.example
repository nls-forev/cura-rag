# Copy to .env and fill in. Never commit .env.

# --- LLM provider ---
# One of: deepseek | openai | anthropic
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1

# Provider API keys (set only the one you use)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Embeddings / reranker ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=curarag

# --- Retrieval tunables ---
CHUNKING_STRATEGY=recursive        # fixed | recursive | semantic
DENSE_TOP_K=30
SPARSE_TOP_K=30
RRF_K=60
RERANK_TOP_K=5

# --- Safety / abstain ---
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35

# --- Data sources ---
OPENFDA_BASE_URL=https://api.fda.gov/drug/label.json
